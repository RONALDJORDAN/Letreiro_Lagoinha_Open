<Window x:Class="LetreiroDigital.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bem-vindo ao Letreiro Digital" Height="500" Width="800"
        Background="#0B0B13" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" WindowStyle="None" AllowsTransparency="True"
        Icon="pack://application:,,,/Assets/app_icon.ico">
    
    <Window.Resources>
        <!-- Estilo dos Cards (Hover e Transformação) -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#151525"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Opacity" Value="0"/> <!-- Inicia invisível para a animação -->
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="50"/> <!-- Inicia deslocado para baixo -->
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#1C1C30" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#151525" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="WindowLoadAnimation">
            <!-- Fade in da janela inteira -->
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
            
            <!-- Cascata dos cards -->
            <!-- Card 1 -->
            <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.5" BeginTime="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Card 2 -->
            <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.5" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Card 3 -->
            <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.7"/>
            <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.5" BeginTime="0:0:0.7">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowLoadAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder" CornerRadius="15" Background="#0B0B13" BorderBrush="#2A2A40" BorderThickness="1" Opacity="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de Título Customizada -->
            <Grid Grid.Row="0" Background="#151525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border CornerRadius="15,15,0,0" />
                <TextBlock Text="Letreiro Digital - Bem-vindo" Foreground="#E3E0F2" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,10"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="30" 
                        Background="Transparent" Foreground="#E3E0F2" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF4C4C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Área de Conteúdo / Cards -->
            <Grid Grid.Row="1" Margin="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1 -->
                <Border x:Name="Card1" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📺" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Múltiplas Telas" Foreground="#513BA6" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Controle múltiplos monitores, TVs e projetores de forma independente e simultânea." Foreground="#A1A1AA" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border x:Name="Card2" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Personalização Total" Foreground="#4EDEA3" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Crie painéis incríveis, altere temas em tempo real, use suas próprias cores e layouts." Foreground="#A1A1AA" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border x:Name="Card3" Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔓" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Open Source" Foreground="#FFD666" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Totalmente livre, gratuito e pronto para uso nativo. Sem limites de licenciamento!" Foreground="#A1A1AA" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Rodapé com Botão e Loading -->
            <StackPanel Grid.Row="2" Margin="0,0,0,30" HorizontalAlignment="Center">
                <Button x:Name="BtnIniciar" Content="INICIAR SISTEMA" Foreground="White" FontWeight="Bold" FontSize="16" 
                        Width="250" Height="45" Cursor="Hand" Click="BtnIniciar_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#513BA6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#674BC7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel x:Name="PanelLoading" Orientation="Vertical" Visibility="Collapsed" Margin="0,15,0,0">
                    <ProgressBar x:Name="ProgressCheck" Width="250" Height="6" IsIndeterminate="True" Foreground="#4EDEA3" Background="#1A1A2E" BorderThickness="0"/>
                    <TextBlock x:Name="LblStatus" Text="Verificando dependências locais..." Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>

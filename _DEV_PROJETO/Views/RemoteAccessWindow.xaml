<Window x:Class="LetreiroDigital.Views.RemoteAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Acesso Remoto" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="CONFIGURAÇÃO DE ACESSO" Foreground="#FFD700" FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>

            <TextBlock Text="Porta do Servidor (Padrão: 8080)" Foreground="#CCC" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPort" Background="#333" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Senha Fixa (Opcional)" Foreground="#CCC" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPassword" Background="#333" Foreground="White" BorderThickness="0" Padding="5" Margin="0,0,0,5"/>
            <TextBlock Text="Deixe em branco para perguntar ao iniciar ou gerar aleatória." 
                       Foreground="#777" FontSize="11" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnCancel" Content="Cancelar" Width="100" Height="30" Margin="0,0,10,0"
                        Background="#444" Foreground="White" BorderThickness="0" Click="BtnCancel_Click"/>
                
                <Button x:Name="btnSave" Content="Salvar" Width="100" Height="30"
                        Background="#00E676" Foreground="#111" FontWeight="Bold" BorderThickness="0" Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

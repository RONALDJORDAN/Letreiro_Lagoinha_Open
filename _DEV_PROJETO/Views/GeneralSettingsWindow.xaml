<Window x:Class="LetreiroDigital.Views.GeneralSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LetreiroDigital.ViewModels"
        mc:Ignorable="d"
        Title="Configurações e Info" SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="CONFIGURAÇÕES GERAIS" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="#4CAF50" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Border Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ Gerenciamento Automático" 
                               Foreground="#FFD700" 
                               FontSize="14" FontWeight="Bold" 
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="As configurações de exibição (Relógio, Banner, Cronograma e Presets) agora são gerenciadas automaticamente conforme o Modo de Exibição selecionado (F1/F2) e atalhos de teclado (F5-F11)." 
                               Foreground="#BBB" 
                               TextWrapping="Wrap" 
                               LineHeight="18"/>

                    <TextBlock Text="Isso garante que o layout permaneça consistente e otimizado para a transmissão." 
                               Foreground="#888" 
                               FontSize="11"
                               FontStyle="Italic"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Button Content="Fechar" HorizontalAlignment="Right" Click="BtnClose_Click" Width="100"/>
        </StackPanel>
    </Border>
</Window>

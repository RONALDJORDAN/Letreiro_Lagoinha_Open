<Window x:Class="LetreiroDigital.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar Cor" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="HexagonButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Path Data="M 12,0 L 24,7 L 24,21 L 12,28 L 0,21 L 0,7 Z"
                                  Fill="{TemplateBinding Background}"
                                  Stroke="Transparent"
                                  StrokeThickness="1"/>
                            <Path x:Name="Highlight"
                                  Data="M 12,0 L 24,7 L 24,21 L 12,28 L 0,21 L 0,7 Z"
                                  Fill="Transparent"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Highlight" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Highlight" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Highlight" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <!-- Pick a Color Section -->
            <TextBlock Text="Selecione uma Cor:" FontSize="16" Margin="0,0,0,15"/>
            
            <!-- Hexagonal Grid Container -->
            <ItemsControl x:Name="HexGridItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="280" Height="250"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource HexagonButtonStyle}"
                                Background="{Binding ColorBrush}"
                                Click="ColorButton_Click"
                                ToolTip="{Binding ColorHex}">
                            <Button.RenderTransform>
                                <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                            </Button.RenderTransform>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Manual Entry Section -->
            <TextBlock Text="Ou digite o código:" FontSize="16" Margin="0,20,0,10"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#2D2D2D" CornerRadius="4" Padding="5">
                    <TextBox x:Name="txtColorCode" Width="100" 
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" FontSize="14"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtColorCode_TextChanged"/>
                </Border>
                
                <Border x:Name="previewColorBox" Width="30" Height="30" 
                        Margin="10,0" CornerRadius="4" 
                        BorderBrush="Gray" BorderThickness="1"/>
                
                <Button Content="OK" Click="BtnOk_Click"
                        Background="#4CAF50" Foreground="White"
                        Padding="15,5" BorderThickness="0"
                        FontSize="14" FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Button Content="Cancelar" Click="BtnCancel_Click"
                    Background="Transparent" Foreground="#999"
                    Margin="0,15,0,0" BorderThickness="0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="LetreiroDigital.Views.MiniControllerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Controle"
        Width="350" Height="160"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Timer -->
        <TextBlock x:Name="lblTimer" Grid.ColumnSpan="3" Text="--:--"
                   FontSize="36" FontWeight="Bold" Foreground="#00E676"
                   HorizontalAlignment="Center" FontFamily="Consolas"/>

        <!-- Item Name -->
        <TextBlock x:Name="lblItemName" Grid.Row="1" Grid.ColumnSpan="3"
                   Text="Nenhum item" FontSize="12" Foreground="#B0B0B0"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Button x:Name="btnPrev" Grid.Row="2" Grid.Column="0" Content="⬆ ANTERIOR"
                Background="#333" Foreground="White" FontWeight="Bold" FontSize="10"
                Padding="8,6" BorderThickness="0" Cursor="Hand" Margin="0,0,3,0"
                Click="BtnPrev_Click"/>
        <Button x:Name="btnStop" Grid.Row="2" Grid.Column="1" Content="⏹ PARAR"
                Background="#D32F2F" Foreground="White" FontWeight="Bold" FontSize="10"
                Padding="8,6" BorderThickness="0" Cursor="Hand" Margin="3,0"
                Click="BtnStop_Click"/>
        <Button x:Name="btnNext" Grid.Row="2" Grid.Column="2" Content="⬇ PRÓXIMO"
                Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="10"
                Padding="8,6" BorderThickness="0" Cursor="Hand" Margin="3,0,0,0"
                Click="BtnNext_Click"/>
    </Grid>
</Window>

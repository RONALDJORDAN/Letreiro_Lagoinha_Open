<Window x:Class="LetreiroDigital.Views.QrCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conectar Controle Remoto" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    
    <Border Padding="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <TextBlock Text="ACESSO REMOTO" Foreground="#FFD700" FontWeight="Bold" FontSize="18" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="White" Padding="10" CornerRadius="8" HorizontalAlignment="Center">
                <Image x:Name="qrImage" Width="250" Height="250"/>
            </Border>

            <TextBlock x:Name="lblUrl" Text="http://..." Foreground="White" FontSize="14" 
                       HorizontalAlignment="Center" Margin="0,20,0,5" TextDecorations="Underline" Cursor="Hand" MouseLeftButtonDown="LblUrl_Click"/>

            <TextBlock Text="Escaneie com a câmera do celular" Foreground="#AAAAAA" FontSize="12" 
                       HorizontalAlignment="Center"/>

            <Button Content="Fechar" Width="120" Height="35" Margin="0,25,0,0"
                    Background="#333" Foreground="White" BorderThickness="0" Click="BtnClose_Click"/>
        </StackPanel>
    </Border>
</Window>

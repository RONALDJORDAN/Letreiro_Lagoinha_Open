<UserControl x:Class="LetreiroDigital.Views.TvModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="clr-namespace:LetreiroDigital.Converters"
    mc:Ignorable="d"
    d:DesignHeight="1080" d:DesignWidth="1920"
    Background="#11141B">

    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- 7-Segment Display: Relógio e Timer -->
        <FontFamily x:Key="DigitalFont">pack://application:,,,/LetreiroDigital;component/Assets/Fonts/#Digital-7
            Mono</FontFamily>

        <!-- Dot Matrix / LED Board: Rodapé Horário Evento (embutida no app) -->
        <FontFamily x:Key="DotMatrixFont">./Fonts/#Led Board-7, ./Fonts/#LED Board-7, Consolas,
            Courier New</FontFamily>

        <!-- Sans Serif Condensada: Títulos (embutida no app via Google Fonts) -->
        <FontFamily x:Key="CondensedFont">./Fonts/#Oswald, Impact, Arial Black</FontFamily>

        <!-- Sans Serif Moderna: Textos do cronograma e labels -->
        <FontFamily x:Key="StandardFont">Segoe UI, Arial</FontFamily>

        <!-- Colors -->
        <SolidColorBrush x:Key="BgPrimary" Color="#11141B" />
        <SolidColorBrush x:Key="BgSecondary" Color="#1A1D2E" />
        <SolidColorBrush x:Key="BgFooter" Color="#050508" />
        <SolidColorBrush x:Key="TextWhite" Color="#FFFFFF" />
        <SolidColorBrush x:Key="RedTitle" Color="#FF3333" />
        <SolidColorBrush x:Key="RedNeon" Color="#FF0000" />
        <SolidColorBrush x:Key="Border" Color="#2A2D3E" />

        <!-- Animations -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="1.0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="rootGrid" Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVis}}">

        <!-- ==================== LAYOUT 1: Completo (padrão) ==================== -->
        <Grid x:Name="mainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="30*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="55*" />
            <RowDefinition Height="25*" />
            <RowDefinition Height="20*" />
        </Grid.RowDefinitions>


        <!-- ==================== EVENTO ATUAL (Main Event Area) ==================== -->

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
            Background="{Binding PanelPrimaryBgColor, Converter={StaticResource HexToBrush}}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="0,0,2,0">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60,40">

                <!-- "EVENTO ATUAL:" Label -->

                <TextBlock x:Name="lblEventLabel"
                    Text="EVENTO ATUAL:"
                    FontSize="52"
                    FontWeight="Black"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{Binding EventLabelColor, Converter={StaticResource HexToBrush}}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,0,0,30">

                    <TextBlock.Effect>
                        <DropShadowEffect
                            Color="{Binding EventLabelColor, Converter={StaticResource HexToBrush}}"
                            BlurRadius="25" ShadowDepth="0"
                            Opacity="0.6" />
                    </TextBlock.Effect>

                </TextBlock>


                <!-- Main Content: Event Title -->

                <TextBlock x:Name="lblMainContent"
                    Text="AGUARDANDO SELEÇÃO"
                    FontSize="72"
                    FontWeight="Black"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{StaticResource TextWhite}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    MaxWidth="1100"
                    LineHeight="85">

                    <TextBlock.Effect>

                        <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="3"
                            Opacity="0.8" />

                    </TextBlock.Effect>

                </TextBlock>

            </StackPanel>

        </Border>


        <!-- ==================== CRONOGRAMA (Schedule List) ==================== -->

        <Border Grid.Row="0" Grid.Column="1"
            Background="{Binding PanelSecondaryBgColor, Converter={StaticResource HexToBrush}}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="0,0,0,2"
            Padding="25,20">

            <DockPanel>

                <!-- Header -->

                <TextBlock DockPanel.Dock="Top"
                    Text="CRONOGRAMA:"
                    FontSize="28"
                    FontWeight="Bold"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{Binding ScheduleHeaderColor, Converter={StaticResource HexToBrush}}"
                    Margin="0,0,0,18">

                    <TextBlock.Effect>
                        <DropShadowEffect
                            Color="{Binding ScheduleHeaderColor, Converter={StaticResource HexToBrush}}"
                            BlurRadius="15" ShadowDepth="0"
                            Opacity="0.5" />
                    </TextBlock.Effect>

                </TextBlock>


                <!-- Schedule Items List -->

                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled">

                    <StackPanel x:Name="scheduleList" Margin="0,5,0,0" />

                </ScrollViewer>

            </DockPanel>

        </Border>


        <!-- ==================== MINUTOS (Timer) ==================== -->

        <Border Grid.Row="1" Grid.Column="1"
            Background="{Binding PanelSecondaryBgColor, Converter={StaticResource HexToBrush}}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="0,0,0,2"
            Padding="20">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="MINUTOS:"
                    FontSize="22"
                    FontWeight="Bold"
                    FontFamily="{DynamicResource StandardFont}"
                    Foreground="{Binding SimpleLabelColor, Converter={StaticResource HexToBrush}}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8" />


                <!-- LED Timer Display -->
                <Grid HorizontalAlignment="Center">
                    <!-- Ghost Layer -->
                    <TextBlock Text="88:88"
                        FontSize="96"
                        FontWeight="Normal"
                        FontFamily="{DynamicResource DigitalFont}"
                        Foreground="{Binding DigitalTimerColor, Converter={StaticResource HexToBrush}}"
                        Opacity="0.08"
                        HorizontalAlignment="Center" />

                    <!-- Active Layer -->
                    <TextBlock x:Name="lblTimer"
                        Text="--:--"
                        FontSize="96"
                        FontWeight="Normal"
                        FontFamily="{DynamicResource DigitalFont}"
                        Foreground="{Binding DigitalTimerColor, Converter={StaticResource HexToBrush}}"
                        HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect
                                Color="{Binding DigitalTimerColor, Converter={StaticResource HexToBrush}}"
                                BlurRadius="20" ShadowDepth="0" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>

            </StackPanel>

        </Border>


        <!-- ==================== RELÓGIO (Clock) ==================== -->

        <Border Grid.Row="2" Grid.Column="1"
            Background="{Binding PanelSecondaryBgColor, Converter={StaticResource HexToBrush}}"
            Padding="20">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="RELÓGIO:"
                    FontSize="22"
                    FontWeight="Bold"
                    FontFamily="{DynamicResource StandardFont}"
                    Foreground="{Binding SimpleLabelColor, Converter={StaticResource HexToBrush}}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8" />


                <!-- LED Clock Display -->
                <Grid HorizontalAlignment="Center">
                    <!-- Ghost Layer -->
                    <TextBlock Text="88:88"
                        FontSize="88"
                        FontWeight="Normal"
                        FontFamily="{DynamicResource DigitalFont}"
                        Foreground="{Binding DigitalClockColor, Converter={StaticResource HexToBrush}}"
                        Opacity="0.08"
                        HorizontalAlignment="Center" />

                    <!-- Active Layer -->
                    <TextBlock x:Name="lblClock"
                        Text="--:--"
                        FontSize="88"
                        FontWeight="Normal"
                        FontFamily="{DynamicResource DigitalFont}"
                        Foreground="{Binding DigitalClockColor, Converter={StaticResource HexToBrush}}"
                        HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect
                                Color="{Binding DigitalClockColor, Converter={StaticResource HexToBrush}}"
                                BlurRadius="20" ShadowDepth="0" Opacity="0.8" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>

            </StackPanel>

        </Border>


        <!-- ==================== HORÁRIO EVENTO (LED Footer Bar) ==================== -->

        <Border Grid.Row="2" Grid.Column="0"
            Background="{Binding FooterBgColor, Converter={StaticResource HexToBrush}}"
            BorderBrush="#1A0000"
            BorderThickness="0,3,2,0">

            <!-- LED Dot Matrix Effect Background -->

            <Border.Effect>
                <DropShadowEffect
                    Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                    BlurRadius="5" ShadowDepth="0" Opacity="0.2"
                    Direction="90" />
            </Border.Effect>


            <Grid Margin="40,0">

                <!-- LED Style Background Pattern (simulated) -->

                <Rectangle Fill="#000000" Opacity="0.6" />

                <Rectangle Fill="#0A0000" Opacity="0.3">

                    <Rectangle.OpacityMask>

                        <DrawingBrush Viewport="0,0,4,4" ViewportUnits="Absolute" TileMode="Tile">

                            <DrawingBrush.Drawing>

                                <GeometryDrawing Brush="#FF000000">

                                    <GeometryDrawing.Geometry>

                                        <EllipseGeometry RadiusX="1" RadiusY="1" Center="2,2" />

                                    </GeometryDrawing.Geometry>

                                </GeometryDrawing>

                            </DrawingBrush.Drawing>

                        </DrawingBrush>

                    </Rectangle.OpacityMask>

                </Rectangle>


                <!-- LED Text Content -->

                <StackPanel VerticalAlignment="Center" Margin="20,0">

                    <TextBlock x:Name="lblEventTimeHeader"
                        Text="HORÁRIO EVENTO:"
                        FontSize="32"
                        FontWeight="Bold"
                        FontFamily="{DynamicResource DotMatrixFont}"
                        Foreground="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}">

                        <TextBlock.Effect>
                            <DropShadowEffect
                                Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                                BlurRadius="18" ShadowDepth="0"
                                Opacity="0.7" />
                        </TextBlock.Effect>

                    </TextBlock>


                    <TextBlock x:Name="lblEventTimeRange"
                        Text="INÍCIO --:-- — FIM --:--"
                        FontSize="38"
                        FontWeight="Bold"
                        FontFamily="{DynamicResource DotMatrixFont}"
                        Foreground="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                        Margin="0,5,0,0">

                        <TextBlock.Effect>
                            <DropShadowEffect
                                Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                                BlurRadius="18" ShadowDepth="0"
                                Opacity="0.7" />
                        </TextBlock.Effect>

                    </TextBlock>

                </StackPanel>

            </Grid>

        </Border>


        <!-- ==================== LIVE INDICATOR (AO VIVO) ==================== -->

        <Border Grid.Row="0" Grid.Column="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#001A00"
            CornerRadius="8"
            Padding="20,8"
            Margin="30,30,0,0"
            BorderBrush="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
            BorderThickness="2">

            <Border.Effect>
                <DropShadowEffect
                    Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                    BlurRadius="25" ShadowDepth="0" Opacity="0.8" />
            </Border.Effect>


            <StackPanel Orientation="Horizontal">

                <!-- Pulsing Dot -->

                <Ellipse Width="18" Height="18"
                    Fill="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                    Margin="0,0,10,0">

                    <Ellipse.Effect>
                        <DropShadowEffect
                            Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                            BlurRadius="15" ShadowDepth="0"
                            Opacity="1" />
                    </Ellipse.Effect>

                    <Ellipse.Triggers>

                        <EventTrigger RoutedEvent="Loaded">

                            <BeginStoryboard>

                                <Storyboard RepeatBehavior="Forever">

                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                        From="1.0" To="0.3" Duration="0:0:1"
                                        AutoReverse="True" />

                                </Storyboard>

                            </BeginStoryboard>

                        </EventTrigger>

                    </Ellipse.Triggers>

                </Ellipse>


                <!-- AO VIVO Text -->

                <TextBlock Text="AO VIVO"
                    FontSize="32"
                    FontWeight="Black"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}">

                    <TextBlock.Effect>
                        <DropShadowEffect
                            Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                            BlurRadius="20" ShadowDepth="0"
                            Opacity="0.9" />
                    </TextBlock.Effect>

                </TextBlock>

            </StackPanel>

        </Border>



        </Grid>
        <!-- END LAYOUT 1 -->


        <!-- ==================== LAYOUT 2: Letreiro Inferior ==================== -->
        <Grid x:Name="layout2Grid" Visibility="Collapsed"
              Background="{Binding PanelPrimaryBgColor, Converter={StaticResource HexToBrush}}">

            <!-- Background subtle grid pattern for depth, like the reference image -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D0F16" Offset="0" />
                        <GradientStop Color="#111420" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- AO VIVO Badge (top-left) -->
            <Border x:Name="layout2LiveBadge"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="#001500"
                    CornerRadius="8" Padding="20,8" Margin="30,30,0,0"
                    BorderBrush="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                    BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                                      BlurRadius="25" ShadowDepth="0" Opacity="0.8"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="18" Height="18"
                             Fill="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                             Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                                              BlurRadius="15" ShadowDepth="0" Opacity="1"/>
                        </Ellipse.Effect>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="AO VIVO" FontSize="32" FontWeight="Black"
                               FontFamily="{DynamicResource CondensedFont}"
                               Foreground="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{Binding LiveIndicatorColor, Converter={StaticResource HexToBrush}}"
                                              BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Main event title area — center of screen -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="60,0,60,160">

                <!-- Label "EVENTO ATUAL:" -->
                <TextBlock x:Name="layout2EventLabel"
                    Text="EVENTO ATUAL:"
                    FontSize="52" FontWeight="Black"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{Binding EventLabelColor, Converter={StaticResource HexToBrush}}"
                    HorizontalAlignment="Center" TextAlignment="Center"
                    Margin="0,0,0,20">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{Binding EventLabelColor, Converter={StaticResource HexToBrush}}"
                                          BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Main event title -->
                <TextBlock x:Name="layout2MainContent"
                    Text="AGUARDANDO SELEÇÃO"
                    FontSize="96" FontWeight="Black"
                    FontFamily="{DynamicResource CondensedFont}"
                    Foreground="{Binding TitleColor, Converter={StaticResource HexToBrush}}"
                    HorizontalAlignment="Center" TextAlignment="Center"
                    TextWrapping="Wrap">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{Binding TitleColor, Converter={StaticResource HexToBrush}}"
                                          BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

            </StackPanel>

            <!-- Bottom footer bar — HORÁRIO EVENTO / INÍCIO–FIM -->
            <Border VerticalAlignment="Bottom"
                    Background="{Binding FooterBgColor, Converter={StaticResource HexToBrush}}"
                    BorderBrush="#1A0000" BorderThickness="0,3,0,0"
                    Height="160">
                <Border.Effect>
                    <DropShadowEffect Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                                      BlurRadius="5" ShadowDepth="0" Opacity="0.2" Direction="90"/>
                </Border.Effect>
                <Grid Margin="60,0">
                    <!-- LED dot pattern overlay -->
                    <Rectangle Fill="#000000" Opacity="0.5"/>
                    <Rectangle Fill="#0A0000" Opacity="0.25">
                        <Rectangle.OpacityMask>
                            <DrawingBrush Viewport="0,0,4,4" ViewportUnits="Absolute" TileMode="Tile">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="#FF000000">
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry RadiusX="1" RadiusY="1" Center="2,2"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <StackPanel VerticalAlignment="Center" Margin="20,0">
                        <TextBlock x:Name="layout2TimeHeader"
                            Text="HORÁRIO EVENTO:"
                            FontSize="{Binding TvFooterSize}"
                            FontWeight="Bold"
                            FontFamily="{DynamicResource DotMatrixFont}"
                            Foreground="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                                                  BlurRadius="18" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="layout2TimeRange"
                            Text="INÍCIO --:-- — FIM --:--"
                            FontSize="{Binding TvFooterSize}"
                            FontWeight="Bold"
                            FontFamily="{DynamicResource DotMatrixFont}"
                            Foreground="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                            Margin="0,5,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{Binding FooterTextColor, Converter={StaticResource HexToBrush}}"
                                                  BlurRadius="18" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
        <!-- END LAYOUT 2 -->

        <!-- ==================== WARNING OVERLAY (global) ==================== -->
        <Border x:Name="warningOverlay"
            Panel.ZIndex="100"
            Visibility="Collapsed"
            Background="#DDffcc00">
            <Border.Effect>
                <DropShadowEffect Color="#FFD700" BlurRadius="60" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⚠" FontSize="120" FontWeight="Black"
                           Foreground="#1A1000" HorizontalAlignment="Center"
                           Opacity="0.85" Margin="0,0,0,10"/>
                <TextBlock Text="PRÓXIMO ITEM EM BREVE"
                           FontSize="80" FontWeight="Black"
                           FontFamily="{DynamicResource CondensedFont}"
                           Foreground="#1A1000" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,0,0,12">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="lblWarningCountdown"
                           Text="" FontSize="48" FontWeight="Bold"
                           FontFamily="{DynamicResource StandardFont}"
                           Foreground="#1A1000" HorizontalAlignment="Center"
                           Opacity="0.75"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>